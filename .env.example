# Copy to .env and adjust. All vars are prefixed GATEWAY_ (see src/gateway/config.py).
# Defaults already match docker-compose.yml, so .env is optional for local dev.

# --- PostgreSQL ---
GATEWAY_DB_HOST=localhost
GATEWAY_DB_PORT=5432
GATEWAY_DB_USER=gateway
GATEWAY_DB_PASSWORD=gateway
GATEWAY_DB_NAME=gateway

# --- Embeddings (local ONNX via fastembed) ---
GATEWAY_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
GATEWAY_EMBEDDING_DIM=384

# --- Cache similarity gates (1 - cosine distance) ---
GATEWAY_SEMANTIC_THRESHOLD=0.95
GATEWAY_INTENT_THRESHOLD=0.97

# --- Model backend (OpenAI-compatible; local Ollama is the free dev default) ---
# Run `ollama pull gemma3:1b` before using the live path.
GATEWAY_BACKEND_BASE_URL=http://localhost:11434/v1
GATEWAY_BACKEND_MODEL=gemma3:1b
GATEWAY_BACKEND_API_KEY=
GATEWAY_BACKEND_TIMEOUT=30.0
